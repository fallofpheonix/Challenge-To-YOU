[gd_scene load_steps=2 format=3]

[ext_resource type="Script" path="res://ui/components/inspector_modal.gd" id="1"]

[node name="InspectorModal" type="PanelContainer"]
custom_minimum_size = Vector2(600, 450)
anchors_preset = 8
anchor_left = 0.5
anchor_top = 0.5
anchor_right = 0.5
anchor_bottom = 0.5
offset_left = -300.0
offset_top = -225.0
offset_right = 300.0
offset_bottom = 225.0
grow_horizontal = 2
grow_vertical = 2
script = ExtResource("1")

[node name="VBoxContainer" type="VBoxContainer" parent="."]
layout_mode = 2
theme_override_constants/separation = 10

[node name="HeaderPanel" type="HBoxContainer" parent="VBoxContainer"]
layout_mode = 2

[node name="WindowTitle" type="Label" parent="VBoxContainer/HeaderPanel"]
layout_mode = 2
size_flags_horizontal = 3
theme_override_colors/font_color = Color(0, 1, 0.62, 1)
text = "SWARM TELEMETRY INSPECTOR"

[node name="DroneIDLabel" type="Label" parent="VBoxContainer/HeaderPanel"]
layout_mode = 2
text = "ENTITY_ID: 000"

[node name="CodeBuffer" type="CodeEdit" parent="VBoxContainer"]
layout_mode = 2
size_flags_vertical = 3
theme_override_font_sizes/font_size = 13
text = "// Assigned Swarm Transit Protocol
fn main() {
    MOVE_RANDOM();
}"
editable = false
draw_tabs = true
gutters_draw_line_numbers = true

[node name="ActionControls" type="HBoxContainer" parent="VBoxContainer"]
layout_mode = 2
theme_override_constants/separation = 12

[node name="LockToggleBtn" type="Button" parent="VBoxContainer/ActionControls"]
layout_mode = 2
size_flags_horizontal = 3
text = "🔒 Code Locked (Read-Only)"

[node name="ApplyBtn" type="Button" parent="VBoxContainer/ActionControls"]
layout_mode = 2
size_flags_horizontal = 3
disabled = true
text = "🛰️ Deploy Patch & Resume"
