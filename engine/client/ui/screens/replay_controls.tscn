[gd_scene load_steps=2 format=3]

[ext_resource type="Script" path="res://ui/screens/replay_controls.gd" id="1"]

[node name="ReplayControls" type="Control"]
layout_mode = 3
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2
script = ExtResource("1")

[node name="VBoxContainer" type="VBoxContainer" parent="."]
layout_mode = 1
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2
theme_override_constants/separation = 8

[node name="TimelineBar" type="PanelContainer" parent="VBoxContainer"]
layout_mode = 2
custom_minimum_size = Vector2(0, 40)

[node name="HBoxContainer" type="HBoxContainer" parent="VBoxContainer/TimelineBar"]
layout_mode = 2
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2
theme_override_constants/separation = 12

[node name="TickLabel" type="Label" parent="VBoxContainer/TimelineBar/HBoxContainer"]
layout_mode = 2
theme_override_colors/font_color = Color(0, 1, 0.62, 1)
theme_override_font_sizes/font_size = 14
text = "Tick: 0 / 0"

[node name="SeekSlider" type="HSlider" parent="VBoxContainer/TimelineBar/HBoxContainer"]
layout_mode = 2
size_flags_horizontal = 3

[node name="ControlsBar" type="HBoxContainer" parent="VBoxContainer"]
layout_mode = 2
alignment = 1
theme_override_constants/separation = 8

[node name="ResetBtn" type="Button" parent="VBoxContainer/ControlsBar"]
layout_mode = 2
text = "⏮"

[node name="StepBackBtn" type="Button" parent="VBoxContainer/ControlsBar"]
layout_mode = 2
text = "◀"

[node name="PlayBtn" type="Button" parent="VBoxContainer/ControlsBar"]
layout_mode = 2
text = "▶"

[node name="StepForwardBtn" type="Button" parent="VBoxContainer/ControlsBar"]
layout_mode = 2
text = "⏭"

[node name="SpeedDownBtn" type="Button" parent="VBoxContainer/ControlsBar"]
layout_mode = 2
text = "−"

[node name="SpeedLabel" type="Label" parent="VBoxContainer/ControlsBar"]
layout_mode = 2
theme_override_font_sizes/font_size = 13
text = "1.0x"

[node name="SpeedUpBtn" type="Button" parent="VBoxContainer/ControlsBar"]
layout_mode = 2
text = "+"

[node name="HSeparator" type="HSeparator" parent="VBoxContainer"]
layout_mode = 2

[node name="ScrollContainer" type="ScrollContainer" parent="VBoxContainer"]
layout_mode = 2
