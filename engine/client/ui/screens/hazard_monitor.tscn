[gd_scene load_steps=2 format=3]

[ext_resource type="Script" path="res://ui/screens/hazard_monitor.gd" id="1"]

[node name="HazardMonitor" type="Control"]
layout_mode = 3
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2
script = ExtResource("1")

[node name="VBoxContainer" type="VBoxContainer" parent="."]
layout_mode = 1
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2
theme_override_constants/separation = 8

[node name="ThreatBar" type="PanelContainer" parent="VBoxContainer"]
layout_mode = 2
custom_minimum_size = Vector2(0, 40)

[node name="HBoxContainer" type="HBoxContainer" parent="VBoxContainer/ThreatBar"]
layout_mode = 2
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2
theme_override_constants/separation = 16

[node name="GlobalThreat" type="Label" parent="VBoxContainer/ThreatBar/HBoxContainer"]
layout_mode = 2
theme_override_colors/font_color = Color(1, 0.75, 0, 1)
theme_override_font_sizes/font_size = 16
text = "Global Threat Level: SAFE"

[node name="ActiveHazards" type="Label" parent="VBoxContainer/ThreatBar/HBoxContainer"]
layout_mode = 2
theme_override_colors/font_color = Color(0.48, 0.54, 0.6, 1)
theme_override_font_sizes/font_size = 14
text = "Active Hazards: 0"

[node name="ToggleOverlayBtn" type="Button" parent="VBoxContainer/ThreatBar/HBoxContainer"]
layout_mode = 2
size_flags_horizontal = 3
text = "Toggle Overlay"

[node name="HSeparator" type="HSeparator" parent="VBoxContainer"]
layout_mode = 2

[node name="ScrollContainer" type="ScrollContainer" parent="VBoxContainer"]
layout_mode = 2
size_flags_vertical = 3

[node name="HazardList" type="VBoxContainer" parent="VBoxContainer/ScrollContainer"]
layout_mode = 2
size_flags_horizontal = 3
theme_override_constants/separation = 2

[connection signal="pressed" from="VBoxContainer/ThreatBar/HBoxContainer/ToggleOverlayBtn" to="." method="_on_toggle_overlay_pressed"]
