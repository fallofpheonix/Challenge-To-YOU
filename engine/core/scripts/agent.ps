fn main() {
    if (SENSE_BATTERY() < 25000000) {
        MOVE_TOWARDS_HOME()
    } else {
        HARVEST()
        DROP_RESOURCE()
        
        if (SENSE_RESOURCE()) {
            MOVE_TOWARDS_RESOURCE()
        } else {
            if (SENSE_HOME()) {
                MOVE_TOWARDS_HOME()
            } else {
                MOVE_RANDOM()
            }
        }
    }
}
