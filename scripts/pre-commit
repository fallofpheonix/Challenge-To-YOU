#!/usr/bin/env bash
# scripts/pre-commit — Git pre-commit hook
# Installed via: make install-hooks
set -euo pipefail

RED='\033[0;31m'
GREEN='\033[0;32m'
NC='\033[0m'

echo "Running pre-commit checks..."

# ── 1. Check formatting ────────────────────────────────────
echo "  [1/3] Checking gofmt..."
UNCHANGED=$(gofmt -l backend/ phoenix/ 2>/dev/null || true)
if [ -n "$UNCHANGED" ]; then
  echo -e "${RED}FAIL${NC}: Files need formatting:"
  echo "$UNCHANGED"
  echo "Run: make fmt"
  exit 1
fi
echo -e "  ${GREEN}OK${NC}"

# ── 2. Run go vet on changed packages ──────────────────────
echo "  [2/3] Running go vet..."
CHANGED_GO=$(git diff --cached --name-only --diff-filter=ACM -- '*.go' 2>/dev/null || true)
if [ -n "$CHANGED_GO" ]; then
  PACKAGES=$(echo "$CHANGED_GO" | sed 's|/[^/]*$||' | sort -u | grep -E '^backend/' | head -5 || true)
  for pkg in $PACKAGES; do
    DIR=$(echo "$pkg" | sed 's|^backend/||')
    if [ -d "backend/$DIR" ]; then
      cd backend && go vet "./$DIR/..." 2>&1 && cd .. || { echo -e "${RED}FAIL${NC}: go vet failed in $pkg"; exit 1; }
    fi
  done
fi
echo -e "  ${GREEN}OK${NC}"

# ── 3. Quick test on changed packages ──────────────────────
echo "  [3/3] Running tests on changed packages..."
CHANGED_TESTS=$(git diff --cached --name-only --diff-filter=ACM -- '*_test.go' 2>/dev/null || true)
if [ -n "$CHANGED_TESTS" ]; then
  TEST_PKGS=$(echo "$CHANGED_TESTS" | sed 's|/[^/]*$||' | sort -u | grep -E '^backend/' | head -5 || true)
  for pkg in $TEST_PKGS; do
    DIR=$(echo "$pkg" | sed 's|^backend/||')
    if [ -d "backend/$DIR" ]; then
      cd backend && go test -count=1 -timeout 30s "./$DIR/..." 2>&1 && cd .. || { echo -e "${RED}FAIL${NC}: tests failed in $pkg"; exit 1; }
    fi
  done
fi
echo -e "  ${GREEN}OK${NC}"

echo ""
echo -e "${GREEN}All pre-commit checks passed.${NC}"
