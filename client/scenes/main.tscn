[node name="LuckLabel" type="Label" parent="Margin/VBox/ConfigArea"]
layout_mode = 2
text = "Luck:"

[node name="LuckSpin" type="SpinBox" parent="Margin/VBox/ConfigArea"]
unique_name_in_owner = true
layout_mode = 2
