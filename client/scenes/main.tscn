value = 1.0

[node name="ParadigmLabel" type="Label" parent="Margin/VBox/ConfigArea"]
layout_mode = 2
text = "Era:"

[node name="ParadigmOption" type="OptionButton" parent="Margin/VBox/ConfigArea"]
unique_name_in_owner = true
layout_mode = 2
