{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://challenge-to-you/schemas/mission/v1.0.0",
  "title": "Mission",
  "description": "Schema for story missions in Challenge To YOU. Each mission is a narrative container that organizes challenges, NPCs, and story events.",
  "type": "object",
  "required": [
    "schema_version", "id", "version", "world", "area", "era", "campaign",
    "title", "subtitle", "story_arc", "narrative_summary",
    "prerequisites", "required_challenges", "optional_challenges",
    "npcs", "objectives", "dialogue_sequences", "ambient_events",
    "rewards", "unlock_tree", "lore_entries", "cutscene_refs",
    "xp_reward", "credits_reward"
  ],
  "additionalProperties": false,
  "properties": {
    "schema_version": { "type": "string", "pattern": "^\\d+\\.\\d+\\.\\d+$" },
    "id": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_]*$",
      "description": "Unique mission ID. Format: {era_prefix}_campaign_{seq} or prologue_{seq}",
      "examples": ["mg_campaign_01", "cp_campaign_07", "cos_campaign_03", "prologue_01"]
    },
    "version": { "type": "string", "pattern": "^\\d+\\.\\d+\\.\\d+$" },
    "world": {
      "type": "string",
      "enum": ["aegis_realm", "neon_sprawl", "cosmic_void", "the_junction"],
      "description": "Which world/dimension this mission takes place in"
    },
    "area": {
      "type": "string",
      "description": "Specific location within the world",
      "examples": ["Elder Rune Archives", "District 7 Server Farm", "The Singularity Gate"]
    },
    "era": {
      "type": "string",
      "enum": ["magitech", "cyberpunk", "cosmic", "cross_era"]
    },
    "campaign": {
      "type": "string",
      "enum": ["prologue", "magitech_campaign", "cyberpunk_campaign", "cosmic_campaign"]
    },
    "title": { "type": "string", "minLength": 3, "maxLength": 80 },
    "subtitle": { "type": "string", "maxLength": 120 },
    "story_arc": { "type": "string" },
    "narrative_summary": {
      "type": "string",
      "minLength": 100,
      "description": "Full narrative description of what happens in this mission"
    },
    "mission_type": {
      "type": "string",
      "enum": ["main_story", "side_quest", "tutorial", "boss", "epilogue", "secret"]
    },
    "difficulty_range": {
      "type": "object",
      "required": ["min", "max"],
      "properties": {
        "min": { "type": "number", "minimum": 0.0, "maximum": 1.0 },
        "max": { "type": "number", "minimum": 0.0, "maximum": 1.0 }
      }
    },
    "prerequisites": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Mission IDs that must be completed before this mission unlocks"
    },
    "required_challenges": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Challenge IDs that must be completed to finish this mission"
    },
    "optional_challenges": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Challenge IDs that are optional side objectives"
    },
    "npcs": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["npc_id", "role"],
        "properties": {
          "npc_id": { "type": "string" },
          "role": { "type": "string", "enum": ["quest_giver", "mentor", "antagonist", "ally", "neutral", "vendor", "informant"] },
          "location": { "type": "string" },
          "dialogue_tree_id": { "type": "string" }
        }
      }
    },
    "objectives": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "description", "type", "required"],
        "properties": {
          "id": { "type": "string" },
          "description": { "type": "string" },
          "type": { "type": "string", "enum": ["complete_challenge", "talk_to_npc", "explore_area", "find_item", "trigger_event"] },
          "required": { "type": "boolean" },
          "challenge_id": { "type": "string" },
          "npc_id": { "type": "string" },
          "item_id": { "type": "string" }
        }
      }
    },
    "dialogue_sequences": {
      "type": "array",
      "description": "Ordered dialogue events that play during this mission",
      "items": {
        "type": "object",
        "required": ["trigger", "dialogue_tree_id"],
        "properties": {
          "trigger": {
            "type": "string",
            "enum": ["mission_start", "challenge_complete", "challenge_fail", "mission_complete", "on_enter_area", "manual"]
          },
          "dialogue_tree_id": { "type": "string" },
          "challenge_id": { "type": "string" },
          "area_id": { "type": "string" }
        }
      }
    },
    "ambient_events": {
      "type": "array",
      "description": "Background events that fire randomly or on a schedule during the mission",
      "items": {
        "type": "object",
        "required": ["id", "description"],
        "properties": {
          "id": { "type": "string" },
          "description": { "type": "string" },
          "frequency": { "type": "string", "enum": ["rare", "occasional", "frequent"] },
          "sound_cue": { "type": "string" },
          "dialogue_ref": { "type": "string" }
        }
      }
    },
    "rewards": {
      "type": "object",
      "properties": {
        "xp": { "type": "integer", "minimum": 0 },
        "credits": { "type": "integer", "minimum": 0 },
        "items": { "type": "array", "items": { "type": "string" } },
        "achievements": { "type": "array", "items": { "type": "string" } },
        "unlocks": { "type": "array", "items": { "type": "string" } },
        "lore_entries": { "type": "array", "items": { "type": "string" } }
      }
    },
    "xp_reward": { "type": "integer", "minimum": 0 },
    "credits_reward": { "type": "integer", "minimum": 0 },
    "unlock_tree": {
      "type": "object",
      "description": "What this mission unlocks upon completion",
      "properties": {
        "missions": { "type": "array", "items": { "type": "string" } },
        "areas": { "type": "array", "items": { "type": "string" } },
        "challenges": { "type": "array", "items": { "type": "string" } },
        "items": { "type": "array", "items": { "type": "string" } }
      }
    },
    "lore_entries": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Lore entry IDs revealed upon mission completion"
    },
    "cutscene_refs": {
      "type": "object",
      "properties": {
        "intro": { "type": "string" },
        "outro": { "type": "string" },
        "mid_mission": { "type": "array", "items": { "type": "string" } }
      }
    },
    "music_track": {
      "type": "string",
      "description": "BGM track identifier for this mission"
    },
    "atmosphere": {
      "type": "string",
      "enum": ["tense", "mysterious", "action", "exploration", "horror", "triumph", "melancholy", "neutral"]
    },
    "estimated_duration_minutes": { "type": "integer", "minimum": 5 },
    "analytics_tags": { "type": "array", "items": { "type": "string" } }
  }
}
