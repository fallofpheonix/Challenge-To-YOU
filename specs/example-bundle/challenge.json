{
  "schema_version": "2.0.0",
  "id": "magitech_001",
  "name": "The Breach",
  "paradigm": "MAGITECH",
  "description": "Infiltrate the ancient firewall by exploiting buffer overflow vulnerabilities in the rune sequences.",
  "skill_type": "breach",
