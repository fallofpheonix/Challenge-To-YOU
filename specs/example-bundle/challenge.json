      ],
      "mutations": [
        {
          "target_state_key": "access_level",
          "mutation_value": 3
        }
      ],
      "fallback_mutations": []
    }
  ],
  "win_condition": {
    "target_state_key": "access_level",
    "expected_value": 3
  },
