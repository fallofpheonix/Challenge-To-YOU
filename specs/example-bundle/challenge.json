  "flaws": [
    {
      "id": "flaw_001",
      "trigger_event": "EXECUTE_RUNE",
      "name": "Overflow the Buffer",
      "flavor_text": "The ancient rune overflows its allocated memory space.",
      "conditions": [
        {
          "state_key": "firewall_integrity",
          "operator": "EQUALS",
          "value": 100
        }
      ],
      "mutations": [
        {
          "target_state_key": "firewall_integrity",
          "mutation_value": -25
        }
      ],
      "fallback_mutations": [
        {
          "target_state_key": "alert_status",
          "mutation_value": "ELEVATED"
        }
      ]
    },
    {
      "id": "flaw_002",
      "trigger_event": "EXECUTE_RUNE",
      "name": "Cascade Failure",
      "flavor_text": "The weakened firewall cascades under repeated assault.",
      "conditions": [
        {
          "state_key": "firewall_integrity",
          "operator": "LESS_THAN",
          "value": 75
        },
        {
          "state_key": "firewall_integrity",
          "operator": "GREATER_THAN",
          "value": 0
        }
      ],
      "mutations": [
        {
          "target_state_key": "firewall_integrity",
          "mutation_value": -30
        },
        {
          "target_state_key": "access_level",
          "mutation_value": 1
        }
      ],
      "fallback_mutations": [
        {
          "target_state_key": "alert_status",
          "mutation_value": "HIGH"
        }
      ]
    },
    {
      "id": "flaw_003",
      "trigger_event": "EXECUTE_RUNE",
      "name": "Final Breach",
      "flavor_text": "The firewall shatters, granting full access.",
      "conditions": [
        {
          "state_key": "firewall_integrity",
          "operator": "EQUALS",
          "value": 0
